{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YouTube Audio Remasterer",
  "version": "0.1.0",
  "identifier": "com.jesusgalindez.remasteraudio",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "windows": [
      {
        "title": "YouTube Audio Remasterer",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "url": "http://localhost:8000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
